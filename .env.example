# -------------------------------------------------------
# Copia este archivo a .env y ajusta los valores
# Para dev local: usa los valores por defecto de abajo
# Para producción (Supabase): cambia DATABASE_URL
# -------------------------------------------------------

# Base de datos
# Local (Docker Compose — usa el hostname del servicio "db"):
DATABASE_URL=postgres://postgres:postgres@db:5432/proyecto_electrico
# Supabase (producción) — descomenta y reemplaza:
# DATABASE_URL=postgres://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
# Supabase con schema específico:
# DATABASE_URL=postgres://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?options=-c%20search_path%3D[SCHEMA],public

# Backend
HOST=0.0.0.0
PORT=3000
JWT_SECRET=change_this_in_production_use_at_least_32_random_chars

# Frontend (Vite build-time)
VITE_API_URL=http://localhost:3000
